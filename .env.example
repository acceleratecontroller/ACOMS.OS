# ACOMS.OS Environment Variables
# Copy this file to .env and fill in your values.

# Database connection string (PostgreSQL) — use the pooled connection
DATABASE_URL="postgresql://user:password@localhost:5432/acoms_os"

# Direct (non-pooled) database connection — required for Prisma migrations on Neon
# On Neon, remove "-pooler" from the hostname to get the direct URL
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/acoms_os"

# NextAuth.js
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ACOMS.Auth OIDC Configuration
ACOMS_AUTH_URL="https://acoms-auth.vercel.app"
ACOMS_AUTH_CLIENT_ID="acoms-os"
ACOMS_AUTH_CLIENT_SECRET="your-client-secret-here"
ACOMS_AUTH_SERVICE_TOKEN="your-service-token-here"

# Service Token (for external portals — Controller, WIP — to call OS employee APIs)
# Generate with: openssl rand -hex 32
ACOMS_OS_SERVICE_TOKEN="your-os-service-token-here"

# Google Maps API Key (for address autocomplete)
# Enable the Places API in your Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key-here"
