# ACOMS.OS Environment Variables
# Copy this file to .env and fill in your values.

# Database connection string (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/acoms_os"

# NextAuth.js
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Two-Factor Authentication Encryption Key
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TWO_FACTOR_ENCRYPTION_KEY="your-64-char-hex-key-here"

# Google Maps API Key (for address autocomplete)
# Enable the Places API in your Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key-here"
