// ACOMS.OS — Prisma Database Schema
// This is the single source of truth for the database structure.
//
// BUSINESS DISTINCTION:
//   Employee = A real person / business record in the company.
//              Not every employee will have login access.
//              Login access is managed via ACOMS.Auth (external SSO).
//              The identityId field links to the ACOMS.Auth identity UUID.
//
//   Asset    = Smaller, portable, or general company items.
//              Examples: drills, tools, phones, laptops, PPE.
//              Can be assigned to an Employee.
//
//   Plant    = Larger operational equipment and machinery.
//              Examples: cars, trucks, excavators, generators.
//              Can optionally be assigned to an Employee.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  ADMIN
  STAFF
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum Location {
  BRISBANE
  BUNDABERG
  HERVEY_BAY
  MACKAY
  OTHER
}

enum RoleType {
  OFFICE
  FIELD
}

enum EmploymentType {
  FULL_TIME
  TRAINEE
  CASUAL
  ABN
}

enum AssetStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  RETIRED
  EXPIRED
}

enum ItemCondition {
  NEW
  GOOD
  FAIR
  POOR
}

enum PlantStatus {
  OPERATIONAL
  MAINTENANCE
  DECOMMISSIONED
  STANDBY
}

// ─── Training Matrix Enums ──────────────────────────────

enum TrainingRoleCategory {
  OFFICE
  FIELD
}

enum AccreditationStatus {
  PENDING
  VERIFIED
  EXPIRED
  EXEMPT
}

// ─── Audit Log ──────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid())
  entityType   String   // "Employee", "Asset", "Plant"
  entityId     String   // The record's UUID
  action       String   // "CREATE", "UPDATE", "ARCHIVE", "RESTORE"
  entityLabel  String   // Human-readable label, e.g. "John Smith (E0012)"
  changes      Json?    // { field: { from: old, to: new } } — null for CREATE/ARCHIVE/RESTORE
  performedById String  // ACOMS.Auth identity ID (no local FK)
  performedAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([performedAt])
}

// ─── Employee (Business Record) ─────────────────────────

model Employee {
  id             String         @id @default(uuid())
  employeeNumber String           @unique  // Auto-generated: E0001, E0002, etc.
  firstName      String
  lastName       String

  // Optional link to ACOMS.Auth identity for login access
  identityId     String?        @unique
  email          String?                   // Work email
  personalEmail  String?                   // Personal email
  phone          String?
  address        String?                   // Residential address
  dateOfBirth    DateTime?
  shirtSize      String?                   // Uniform shirt size
  pantsSize      String?                   // Uniform pants size
  roleType       RoleType?                 // Legacy — replaced by EmployeeRole assignments
  employmentType EmploymentType            // Full-Time, Trainee, Casual, ABN
  location       Location                  // Brisbane, Bundaberg, Hervey Bay, Mackay, Other
  startDate      DateTime
  endDate        DateTime?
  probationDate  DateTime?                 // Probation review date
  status         EmployeeStatus   @default(ACTIVE)
  notes          String?

  // Emergency contact
  emergencyFirstName  String?
  emergencyLastName   String?
  emergencyRelation   String?               // WIFE, HUSBAND, PARTNER, MUM, DAD, SISTER, BROTHER, FAMILY, FRIEND, OTHER
  emergencyPhone      String?
  emergencyPhoneAlt   String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdById  String   // ACOMS.Auth identity ID
  updatedById  String?  // ACOMS.Auth identity ID — who last updated this record

  isArchived   Boolean  @default(false)
  archivedAt   DateTime?
  archivedById String?  // ACOMS.Auth identity ID

  // Reverse relations: items assigned to this employee
  assignedAssets Asset[] @relation("AssetAssignedToEmployee")
  assignedPlant  Plant[] @relation("PlantAssignedToEmployee")

  // Training matrix relations
  trainingRoles          EmployeeRole[]
  accreditations         EmployeeAccreditation[]
}

// ─── Plant–Asset Link (many-to-many with history) ───────
// Links assets to plant items (e.g. first aid kit in a vehicle).
// When unlinkedAt is null, the link is active.

model PlantAssetLink {
  id         String    @id @default(uuid())
  plantId    String
  plant      Plant     @relation(fields: [plantId], references: [id])
  assetId    String
  asset      Asset     @relation(fields: [assetId], references: [id])
  notes      String?
  linkedAt   DateTime  @default(now())
  unlinkedAt DateTime?

  @@unique([plantId, assetId, linkedAt])
  @@index([plantId])
  @@index([assetId])
}

// ─── Asset (Smaller / Portable Items) ───────────────────
// Examples: drills, tools, phones, laptops, PPE

model Asset {
  id           String         @id @default(uuid())
  assetNumber  String         @unique
  name         String
  category     String
  make         String?
  model        String?
  serialNumber String?
  purchaseDate DateTime?
  purchaseCost Decimal?
  location     Location?
  status       AssetStatus    @default(AVAILABLE)
  condition    ItemCondition?
  notes        String?

  // Expiration tracking
  expires        Boolean   @default(false)
  expirationDate DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdById  String   // ACOMS.Auth identity ID
  updatedById  String?  // ACOMS.Auth identity ID — who last updated this record

  // Optional assignment to an Employee
  assignedTo   Employee? @relation("AssetAssignedToEmployee", fields: [assignedToId], references: [id])
  assignedToId String?

  isArchived   Boolean  @default(false)
  archivedAt   DateTime?
  archivedById String?  // ACOMS.Auth identity ID

  // Plant links — assets linked to plant items
  plantLinks   PlantAssetLink[]
}

// ─── Plant (Larger Operational Equipment) ────────────────
// Examples: cars, trucks, excavators, generators

model Plant {
  id                        String         @id @default(uuid())
  plantNumber               String         @unique
  category                  String
  stateRegistered           String?
  registrationNumber        String?
  vinNumber                 String?
  year                      Int?
  make                      String?
  model                     String?
  licenceType               String?
  location                  Location?
  assignedToId              String?
  ampolCardNumber           String?
  ampolCardExpiry           DateTime?
  linktTagNumber            String?
  fleetDynamicsSerialNumber String?
  coiExpirationDate         DateTime?
  purchaseDate              DateTime?
  purchasePrice             Decimal?
  soldDate                  DateTime?
  soldPrice                 Decimal?
  comments                  String?
  lastServiceDate           DateTime?
  nextServiceDue            DateTime?
  status                    PlantStatus    @default(OPERATIONAL)
  condition                 ItemCondition?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdById  String   // ACOMS.Auth identity ID
  updatedById  String?  // ACOMS.Auth identity ID — who last updated this record

  // Optional assignment to an Employee
  assignedTo   Employee? @relation("PlantAssignedToEmployee", fields: [assignedToId], references: [id])

  isArchived   Boolean  @default(false)
  archivedAt   DateTime?
  archivedById String?  // ACOMS.Auth identity ID

  // Linked assets (e.g. first aid kit, fire extinguisher)
  assetLinks   PlantAssetLink[]
}

// ─── Training Matrix ────────────────────────────────────
// Roles group skills. Skills link to accreditations.
// Chain: Role → Skill → Accreditation

model TrainingRole {
  id          String               @id @default(uuid())
  roleNumber  String               @unique  // Auto: ROLE-0001
  name        String
  description String?
  category    TrainingRoleCategory

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdById  String   // ACOMS.Auth identity ID

  isArchived   Boolean  @default(false)
  archivedAt   DateTime?
  archivedById String?  // ACOMS.Auth identity ID

  skillLinks   RoleSkillLink[]
  employees    EmployeeRole[]
}

model TrainingSkill {
  id          String  @id @default(uuid())
  skillNumber String  @unique  // Auto: SKILL-0001
  name        String
  description String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdById  String   // ACOMS.Auth identity ID

  isArchived   Boolean  @default(false)
  archivedAt   DateTime?
  archivedById String?  // ACOMS.Auth identity ID

  roleLinks           RoleSkillLink[]
  accreditationLinks  SkillAccreditationLink[]
}

model Accreditation {
  id                   String  @id @default(uuid())
  accreditationNumber  String  @unique  // Auto: ACCR-0001
  code                 String?           // External code e.g. HLTAID011
  name                 String
  description          String?

  // Expiry / renewal settings
  expires       Boolean @default(false)  // Does this accreditation expire?
  renewalMonths Int?                     // Renewal frequency in months (e.g. 12, 24, 36)
  renewalNotes  String?                  // E.g. "Must complete refresher course"

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdById  String   // ACOMS.Auth identity ID

  isArchived   Boolean  @default(false)
  archivedAt   DateTime?
  archivedById String?  // ACOMS.Auth identity ID

  skillLinks  SkillAccreditationLink[]
  employees   EmployeeAccreditation[]
}

// ─── Training Link Tables ────────────────────────────────

model RoleSkillLink {
  id       String        @id @default(uuid())
  roleId   String
  role     TrainingRole  @relation(fields: [roleId], references: [id])
  skillId  String
  skill    TrainingSkill @relation(fields: [skillId], references: [id])
  required Boolean       @default(true)

  @@unique([roleId, skillId])
  @@index([roleId])
  @@index([skillId])
}

model SkillAccreditationLink {
  id               String        @id @default(uuid())
  skillId          String
  skill            TrainingSkill @relation(fields: [skillId], references: [id])
  accreditationId  String
  accreditation    Accreditation @relation(fields: [accreditationId], references: [id])
  required         Boolean       @default(true)

  @@unique([skillId, accreditationId])
  @@index([skillId])
  @@index([accreditationId])
}

// ─── Employee Training Assignments ───────────────────────

model EmployeeRole {
  id         String       @id @default(uuid())
  employeeId String
  employee   Employee     @relation(fields: [employeeId], references: [id])
  roleId     String
  role       TrainingRole @relation(fields: [roleId], references: [id])
  assignedAt DateTime     @default(now())

  @@unique([employeeId, roleId])
  @@index([employeeId])
  @@index([roleId])
}

model EmployeeAccreditation {
  id                String              @id @default(uuid())
  employeeId        String
  employee          Employee            @relation(fields: [employeeId], references: [id])
  accreditationId   String
  accreditation     Accreditation       @relation(fields: [accreditationId], references: [id])
  status            AccreditationStatus @default(PENDING)
  required          Boolean             @default(true)
  issueDate         DateTime?
  expiryDate        DateTime?
  certificateNumber String?
  notes             String?

  // Evidence placeholders — ready for file upload system later
  evidenceFileName  String?
  evidenceFileUrl   String?
  evidenceNotes     String?

  @@unique([employeeId, accreditationId])
  @@index([employeeId])
  @@index([accreditationId])
}
