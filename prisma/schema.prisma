// ACOMS.OS — Prisma Database Schema
// This is the single source of truth for the database structure.
//
// BUSINESS DISTINCTION:
//   User     = A login/account record for accessing the system.
//   Employee = A real person / business record in the company.
//              Not every employee will have a login (User).
//
//   Asset    = Smaller, portable, or general company items.
//              Examples: drills, tools, phones, laptops, PPE.
//              Can be assigned to an Employee.
//
//   Plant    = Larger operational equipment and machinery.
//              Examples: cars, trucks, excavators, generators.
//              Can optionally be assigned to an Employee.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  ADMIN
  STAFF
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum EmployeeLocation {
  BRISBANE
  BUNDABERG
  HERVEY_BAY
  MACKAY
  OTHER
}

enum RoleType {
  OFFICE
  FIELD
}

enum EmploymentType {
  FULL_TIME
  TRAINEE
  CASUAL
  ABN
}

enum AssetStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  RETIRED
}

enum ItemCondition {
  NEW
  GOOD
  FAIR
  POOR
}

enum PlantStatus {
  OPERATIONAL
  MAINTENANCE
  DECOMMISSIONED
  STANDBY
}

// ─── User (Login / Account) ─────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Records this user created
  createdEmployees  Employee[] @relation("EmployeeCreatedBy")
  createdAssets     Asset[]    @relation("AssetCreatedBy")
  createdPlant      Plant[]    @relation("PlantCreatedBy")

  // Records this user archived
  archivedEmployees Employee[] @relation("EmployeeArchivedBy")
  archivedAssets    Asset[]    @relation("AssetArchivedBy")
  archivedPlant     Plant[]    @relation("PlantArchivedBy")

  // Task relations
  createdTasks          Task[]          @relation("TaskCreatedBy")
  archivedTasks         Task[]          @relation("TaskArchivedBy")
  createdRecurringTasks RecurringTask[] @relation("RecurringTaskCreatedBy")
  archivedRecurringTasks RecurringTask[] @relation("RecurringTaskArchivedBy")

  // Audit log entries performed by this user
  auditLogs AuditLog[]
}

// ─── Audit Log ──────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid())
  entityType   String   // "Employee", "Asset", "Plant"
  entityId     String   // The record's UUID
  action       String   // "CREATE", "UPDATE", "ARCHIVE", "RESTORE"
  entityLabel  String   // Human-readable label, e.g. "John Smith (E0012)"
  changes      Json?    // { field: { from: old, to: new } } — null for CREATE/ARCHIVE/RESTORE
  performedBy  User     @relation(fields: [performedById], references: [id])
  performedById String
  performedAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([performedAt])
}

// ─── Employee (Business Record) ─────────────────────────

model Employee {
  id             String         @id @default(uuid())
  employeeNumber String           @unique  // Auto-generated: E0001, E0002, etc.
  firstName      String
  lastName       String
  email          String?                   // Work email
  personalEmail  String?                   // Personal email
  phone          String?
  address        String?                   // Residential address
  dateOfBirth    DateTime?
  shirtSize      String?                   // Uniform shirt size
  pantsSize      String?                   // Uniform pants size
  roleType       RoleType                  // Office or Field
  employmentType EmploymentType            // Full-Time, Trainee, Casual, ABN
  location       EmployeeLocation          // Brisbane, Bundaberg, Hervey Bay, Mackay, Other
  startDate      DateTime
  endDate        DateTime?
  probationDate  DateTime?                 // Probation review date
  status         EmployeeStatus   @default(ACTIVE)
  notes          String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    User     @relation("EmployeeCreatedBy", fields: [createdById], references: [id])
  createdById  String

  isArchived   Boolean  @default(false)
  archivedAt   DateTime?
  archivedBy   User?    @relation("EmployeeArchivedBy", fields: [archivedById], references: [id])
  archivedById String?

  // Reverse relations: items assigned to this employee
  assignedAssets Asset[] @relation("AssetAssignedToEmployee")
  assignedPlant  Plant[] @relation("PlantAssignedToEmployee")

  // Task relations: tasks owned by this employee
  assignedTasks          Task[]          @relation("TaskOwner")
  assignedRecurringTasks RecurringTask[] @relation("RecurringTaskOwner")
}

// ─── Task Enums ───────────────────────────────────────────

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  STUCK
  AWAITING_RESPONSE
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum RecurringFrequency {
  WEEKLY
  FORTNIGHTLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ScheduleType {
  FIXED
  FLOATING
}

// ─── Task (Quick Tasks) ──────────────────────────────────

model Task {
  id         String       @id @default(uuid())
  title      String
  projectId  String?
  notes      String?
  label      String       @default("Task")
  dueDate    DateTime?
  status     TaskStatus   @default(NOT_STARTED)
  priority   TaskPriority @default(LOW)

  ownerId    String
  owner      Employee     @relation("TaskOwner", fields: [ownerId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    User     @relation("TaskCreatedBy", fields: [createdById], references: [id])
  createdById  String

  isArchived   Boolean  @default(false)
  archivedAt   DateTime?
  archivedBy   User?    @relation("TaskArchivedBy", fields: [archivedById], references: [id])
  archivedById String?

  @@index([status])
  @@index([dueDate])
  @@index([ownerId])
}

// ─── Recurring Task ──────────────────────────────────────

model RecurringTask {
  id              String             @id @default(uuid())
  title           String
  description     String?
  category        String             @default("Task")
  frequencyType   RecurringFrequency @default(WEEKLY)
  frequencyValue  Int                @default(1)
  scheduleType    ScheduleType       @default(FLOATING)
  lastCompleted   DateTime?
  nextDue         DateTime?

  ownerId    String
  owner      Employee     @relation("RecurringTaskOwner", fields: [ownerId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    User     @relation("RecurringTaskCreatedBy", fields: [createdById], references: [id])
  createdById  String

  isArchived   Boolean  @default(false)
  archivedAt   DateTime?
  archivedBy   User?    @relation("RecurringTaskArchivedBy", fields: [archivedById], references: [id])
  archivedById String?

  @@index([nextDue])
  @@index([ownerId])
}

// ─── Plant–Asset Link (many-to-many with history) ───────
// Links assets to plant items (e.g. first aid kit in a vehicle).
// When unlinkedAt is null, the link is active.

model PlantAssetLink {
  id         String    @id @default(uuid())
  plantId    String
  plant      Plant     @relation(fields: [plantId], references: [id])
  assetId    String
  asset      Asset     @relation(fields: [assetId], references: [id])
  notes      String?
  linkedAt   DateTime  @default(now())
  unlinkedAt DateTime?

  @@unique([plantId, assetId, linkedAt])
  @@index([plantId])
  @@index([assetId])
}

// ─── Asset (Smaller / Portable Items) ───────────────────
// Examples: drills, tools, phones, laptops, PPE

model Asset {
  id           String         @id @default(uuid())
  assetNumber  String         @unique
  name         String
  category     String
  make         String?
  model        String?
  serialNumber String?
  purchaseDate DateTime?
  purchaseCost Decimal?
  location     String?
  status       AssetStatus    @default(AVAILABLE)
  condition    ItemCondition?
  notes        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    User     @relation("AssetCreatedBy", fields: [createdById], references: [id])
  createdById  String

  // Optional assignment to an Employee
  assignedTo   Employee? @relation("AssetAssignedToEmployee", fields: [assignedToId], references: [id])
  assignedToId String?

  isArchived   Boolean  @default(false)
  archivedAt   DateTime?
  archivedBy   User?    @relation("AssetArchivedBy", fields: [archivedById], references: [id])
  archivedById String?

  // Plant links — assets linked to plant items
  plantLinks   PlantAssetLink[]
}

// ─── Plant (Larger Operational Equipment) ────────────────
// Examples: cars, trucks, excavators, generators

model Plant {
  id                 String         @id @default(uuid())
  plantNumber        String         @unique
  name               String
  category           String
  make               String?
  model              String?
  serialNumber       String?
  yearOfManufacture  Int?
  registrationNumber String?
  purchaseDate       DateTime?
  purchaseCost       Decimal?
  location           String?
  status             PlantStatus    @default(OPERATIONAL)
  condition          ItemCondition?
  lastServiceDate    DateTime?
  nextServiceDue     DateTime?
  notes              String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    User     @relation("PlantCreatedBy", fields: [createdById], references: [id])
  createdById  String

  // Optional assignment to an Employee
  assignedTo   Employee? @relation("PlantAssignedToEmployee", fields: [assignedToId], references: [id])
  assignedToId String?

  isArchived   Boolean  @default(false)
  archivedAt   DateTime?
  archivedBy   User?    @relation("PlantArchivedBy", fields: [archivedById], references: [id])
  archivedById String?

  // Linked assets (e.g. first aid kit, fire extinguisher)
  assetLinks   PlantAssetLink[]
}
